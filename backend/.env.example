# OHS backend .env — production runtime config
# Phase 0.5 — FUSEKI endpoint host/docker 분리 (사용자 비판 #9)

# OpenAI API Key (vision + embedding + text)
OPENAI_API_KEY=sk-your-api-key-here

# Anthropic API Key (Phase 3 LLM reranker; optional until Phase 3)
# ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL (koshaontology single source of truth)
# host eval: localhost / docker compose: kosha-pg
DATABASE_URL=postgresql://kosha:1229@localhost/kosha

# Fuseki SPARQL endpoint
#   host eval (default):       http://localhost:3030/kosha/sparql
#   docker compose container:  http://kosha-fuseki:3030/kosha/sparql
# docker-compose.yml에서 환경변수로 override 권장.
FUSEKI_ENDPOINT=http://localhost:3030/kosha/sparql
FUSEKI_TIMEOUT=5
FUSEKI_ENABLED=true

# Phase 3 SHE rollout feature flags (사용자 비판 #12)
# 단계적 활성화: eval → prod
OHS_ENABLE_SHE=false
OHS_ENABLE_HYBRID_SEARCH=false
OHS_ENABLE_SHE_SPARQL_CHAIN=false

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=[".jpg",".jpeg",".png",".webp"]

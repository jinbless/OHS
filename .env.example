# OHS root .env (영역: top-level orchestration, frontend, optional)
# backend/.env 파일이 별도로 backend 전용 변수 보유.

# OpenAI API Key (vision + embedding + text)
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Domain (without https://) — for production deployments
DOMAIN=your-domain.com

# Anthropic API Key (Phase 3 LLM reranker; optional until Phase 3)
# ANTHROPIC_API_KEY=sk-ant-...
